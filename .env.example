# Copy this to .env and fill in real values. Never commit .env.
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
# Optional: only set this while testing so commands register instantly on one server.
# Remove it (or leave blank) to deploy commands globally (takes up to 1h to propagate).
GUILD_ID=your_test_server_id_here
